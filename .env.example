# OpenCode Initializer — Environment Variables Template
# Copy to .env and fill in your API keys. Never commit .env!

# === Primary Provider (required) ===
DEEPSEEK_API_KEY=sk-your-deepseek-key

# === Cloud Providers (optional) ===
ZAI_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=    # Get from platform.kimi.ai/console/api-keys
MINIMAX_API_KEY=     # Get from platform.minimax.io (Token Plan or Pay-as-you-go)
XAI_API_KEY=
MIMO_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
PERPLEXITY_API_KEY=
ALIBABA_API_KEY=     # Get from dashscope.aliyun.com
DEEPINFRA_API_KEY=

# === Infrastructure (optional) ===
INFRA_SERVICES=postgres,qdrant,redis,prometheus,grafana
ISOLATED_CIRCUIT=false

# === Project settings ===
PROJECT_DIR=$HOME/Projects/my-project
GIT_NAME=
GIT_EMAIL=

